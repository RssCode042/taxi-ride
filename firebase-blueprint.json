{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Information about the passenger or driver",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "phone": { "type": "string" },
        "rating": { "type": "number" },
        "role": { "type": "string", "enum": ["passenger", "driver", "admin"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    },
    "Ride": {
      "title": "Ride History",
      "description": "Details of a completed or active ride",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "passengerUid": { "type": "string" },
        "driverId": { "type": "string" },
        "driverName": { "type": "string" },
        "driverRating": { "type": "number" },
        "carModel": { "type": "string" },
        "carPlate": { "type": "string" },
        "date": { "type": "string" },
        "time": { "type": "string" },
        "destination": { "type": "string" },
        "price": { "type": "number" },
        "status": { "type": "string", "enum": ["searching", "accepted", "completed", "cancelled", "arrived", "in_progress"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "acceptedAt": { "type": "string", "format": "date-time" },
        "cancelledAt": { "type": "string", "format": "date-time" },
        "completedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["passengerUid", "destination", "status"]
    },
    "SavedLocation": {
      "title": "Saved Location",
      "description": "User's frequently visited places",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userUid": { "type": "string" },
        "name": { "type": "string" },
        "address": { "type": "string" },
        "lat": { "type": "number" },
        "lng": { "type": "number" },
        "icon": { "type": "string" }
      },
      "required": ["userUid", "name", "address"]
    }
  },
  "firestore": {
    "/users/{uid}": {
      "schema": "User",
      "description": "User profile data"
    },
    "/rides/{rideId}": {
      "schema": "Ride",
      "description": "Ride records"
    },
    "/users/{uid}/savedLocations/{locationId}": {
      "schema": "SavedLocation",
      "description": "User's saved locations"
    }
  }
}
